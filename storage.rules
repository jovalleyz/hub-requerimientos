rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Logos de tenants — solo ADMIN puede subir; cualquier auth puede leer
    match /tenants/{tenantId}/logo/{file} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Documentos adjuntos a requerimientos — solo miembros del tenant
    match /tenants/{tenantId}/requirements/{reqId}/{file} {
      allow read:  if request.auth != null
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantIds.hasAny([tenantId]);
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantIds.hasAny([tenantId]);
    }

    // Avatares de usuarios
    match /users/{userId}/avatar/{file} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
