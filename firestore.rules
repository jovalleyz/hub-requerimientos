rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantIds.hasAny([tenantId]);
    }

    function hasRole(role) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdminOrManager() {
      return hasRole('ADMIN') || hasRole('MANAGER');
    }

    // Users — readable only to users who share at least one tenant (or themselves)
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantIds.hasAny(resource.data.tenantIds)
      );
      allow create: if request.auth.uid == userId;
      // Self-update is allowed BUT must not change the role field —
      // role changes are ADMIN-only to prevent privilege escalation.
      allow update: if (request.auth.uid == userId && !("role" in request.resource.data.diff(resource.data).affectedKeys()))
                    || hasRole('ADMIN');
      allow delete: if hasRole('ADMIN');

      // Notifications subcollection (path: /users/{userId}/notifications/{notifId})
      match /notifications/{notifId} {
        allow read, update: if isAuthenticated() && request.auth.uid == userId;
        allow create:       if isAuthenticated();
        allow delete:       if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Tenants
    match /tenants/{tenantId} {
      allow read:   if isTenantMember(tenantId);
      allow write:  if hasRole('ADMIN');

      // Requirements dentro del tenant
      match /requirements/{reqId} {
        allow read:   if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && isAdminOrManager();
        allow update: if isTenantMember(tenantId) && (isAdminOrManager() || hasRole('DEV'));
        allow delete: if isTenantMember(tenantId) && hasRole('ADMIN');

        match /tasks/{taskId} {
          allow read, write: if isTenantMember(tenantId);
        }
        match /notes/{noteId} {
          allow read:   if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
          allow update, delete: if request.auth.uid == resource.data.authorId || hasRole('ADMIN');
        }
        match /activity/{actId} {
          allow read:   if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
          allow update, delete: if false; // Log inmutable
        }

        match /documents/{docId} {
          allow read:          if isTenantMember(tenantId);
          allow create, update: if isTenantMember(tenantId) && (isAdminOrManager() || hasRole('DEV'));
          allow delete:        if isTenantMember(tenantId) && isAdminOrManager();
        }
      }

      // Projects
      match /projects/{projectId} {
        allow read:   if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && isAdminOrManager();
        allow update: if isTenantMember(tenantId) && (isAdminOrManager() || hasRole('DEV'));
        allow delete: if isTenantMember(tenantId) && hasRole('ADMIN');
      }

      // Audit log — append-only for tenant members, read for admin/manager
      match /audit/{auditId} {
        allow read:   if isTenantMember(tenantId) && isAdminOrManager();
        allow create: if isTenantMember(tenantId);
        allow update, delete: if false; // Immutable
      }
    }

    // Notifications — solo el dueño
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
